            </header>
                   
                     <section class="main-section bg-light-grey">
        <div class="container py-5">
            <div class="w-lg mx-auto">
                <h1 class="fw-bold mb-2 text-uppercase text-center">Free SVG vector files</h1>
                <h5 class="fw-normal text-center mb-3">Download and upload SVG images with CC0 public domain license
                </h5>
  <form action="/search/" method="POST" >
                <div class="search-bar bg-white px-3 py-3 p-md-2 rounded-3 mb-4 shadow-sm d-md-flex align-items-center">
                    <div class="form-group flex-grow-1">
                        <div class="input-group">
                            <div class="search-icon input-group-text border-0 bg-transparent"><i
                                    class="fa fa-search"></i></div>
